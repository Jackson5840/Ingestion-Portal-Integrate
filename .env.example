# Host ports
ARE_PORT=5000
SIMILARITY_PORT=5003
SWC2PVEC_PORT=5017
REDIS_PORT=6379
POSTGRES_PORT=5432
MYSQL_PORT=3306

# Local data root mounted into the ARE container at the same absolute path.
NMO_DATA_ROOT=/home/kira/app/Ingestion/data

# PostgreSQL used by ARE ingestion/release state.
POSTGRES_DB=nmo
POSTGRES_USER=nmo
POSTGRES_PASSWORD=100neuralDB

# MySQL used by NeuroMorpho/search data.
MYSQL_ROOT_PASSWORD=root
MYSQL_USER=nmo
MYSQL_PASSWORD=nmo
MYSQL_DATABASE=nmdbDev
ARE_MYSQL_DB=nmdbDev
ARE_MYSQL_REVIEW_DB=nmdbDev
ARE_MYSQL_MAIN_DB=NeuMO
SIS_MYSQL_DB=NeuMO

# Set to 1 only when MySQL has the expected NeuroMorpho schema/data
# or similarity-search cache pkl files are present in the image/workdir.
SIS_INIT_ON_STARTUP=0
