# Host ports
ARE_PORT=5000
SIMILARITY_PORT=5003
SWC2PVEC_PORT=5017
REDIS_PORT=6379
POSTGRES_PORT=5432
MYSQL_PORT=3306

# Local data root mounted into the ARE container at the same absolute path.
NMO_DATA_ROOT=/home/user/app/Ingestion/data
NMO_EXPORT_ROOT=/home/user/app/Ingestion/export
NMO_ARCHIVE_EXPORT_ROOT=/home/user/app/Ingestion/dataexport

# PostgreSQL used by ARE ingestion/release state.
POSTGRES_DB=nmo
POSTGRES_USER=your_postgres_user
POSTGRES_PASSWORD=change_me_postgres_password

# MySQL used by NeuroMorpho/search data.
MYSQL_ROOT_PASSWORD=change_me_mysql_root_password
MYSQL_USER=your_mysql_user
MYSQL_PASSWORD=change_me_mysql_password
MYSQL_DATABASE=mysql_DB
ARE_MYSQL_DB=mysql_DB
ARE_MYSQL_REVIEW_DB=mysql_DB
ARE_MYSQL_MAIN_DB=mysql_DB
SIS_MYSQL_DB=mysql_DB

# Set to 1 only when MySQL has the expected NeuroMorpho schema/data
# or similarity-search cache pkl files are present in the image/workdir.
SIS_INIT_ON_STARTUP=0
